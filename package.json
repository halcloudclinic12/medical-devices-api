{
  "name": "healthbox-api",
  "version": "1.0.0",
  "description": "API for healthbox mobile application",
  "main": "dist/start.js",
  "scripts": {
    "build": "tsc && tsc-alias && npm run ejs && npm run static",
    "ejs": "copyfiles -u 1 src/**/*.ejs dist",
    "start": "npm run build && node dist/start.js",
    "static": "copyfiles -u 1 src/**/*.json src/**/*.css src/**/*.jpg src/**/*.png src/**/*.yaml dist",
    "go": "node dist/start.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test-coverage": "jest --coverage",
    "debug": "ndb dist/start.js",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:ci": "cross-env NODE_ENV=test jest --runInBand --coverage",
    "seed": "node dist/seeder/init.js",
    "seed:summary": "node dist/seeder/summary-test-seeder.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.717.0",
    "@aws-sdk/credential-provider-ini": "^3.716.0",
    "@aws-sdk/lib-storage": "^3.717.0",
    "@aws-sdk/s3-request-presigner": "^3.717.0",
    "@elastic/elasticsearch": "^8.17.0",
    "@sendgrid/mail": "^8.1.4",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/dotenv": "^8.2.3",
    "@types/ejs": "^3.1.5",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/moment-timezone": "^0.5.30",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.3",
    "copyfiles": "^2.4.1",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "elasticsearch": "^16.7.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "form-data": "^4.0.2",
    "gupshup-whatsapp-api": "^1.0.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailgun.js": "^12.0.1",
    "moment-timezone": "^0.5.46",
    "mongoose": "^8.9.2",
    "puppeteer": "^24.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@sonar/scan": "^4.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mongoose": "^5.11.97",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.2.2",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.8.3"
  }
}